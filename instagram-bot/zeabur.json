{
  "name": "instagram-dm-bot",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "env": {
    "INSTAGRAM_USERNAME": {
      "description": "Instagram 帳號",
      "required": true
    },
    "INSTAGRAM_PASSWORD": {
      "description": "Instagram 密碼", 
      "required": true
    },
    "DAILY_LIMIT": {
      "description": "每日發送限制",
      "default": "50"
    },
    "HOURLY_LIMIT": {
      "description": "每小時發送限制",
      "default": "10"
    },
    "MIN_INTERVAL": {
      "description": "最小發送間隔(秒)",
      "default": "60"
    },
    "MAX_INTERVAL": {
      "description": "最大發送間隔(秒)",
      "default": "180"
    }
  },
  "port": 5000
}